// Tang Nano 20K Physical Constraints
// Gowin GW2AR-LV18QN88C8/I7

// Clock
IO_LOC  "clk_27m"  4;
IO_PORT "clk_27m"  IO_TYPE=LVCMOS33;

// Button S1 (active low) — active reset
IO_LOC  "btn_s1"   88;
IO_PORT "btn_s1"   IO_TYPE=LVCMOS33 PULL_MODE=UP;

// Button S2 (active low) — bypass toggle
IO_LOC  "btn_s2"   87;
IO_PORT "btn_s2"   IO_TYPE=LVCMOS33 PULL_MODE=UP;

// Onboard LEDs (active low)
IO_LOC  "led[0]"   15;
IO_LOC  "led[1]"   16;
IO_LOC  "led[2]"   17;
IO_LOC  "led[3]"   18;
IO_LOC  "led[4]"   19;
IO_LOC  "led[5]"   20;
IO_PORT "led[0]"   IO_TYPE=LVCMOS33 DRIVE=8;
IO_PORT "led[1]"   IO_TYPE=LVCMOS33 DRIVE=8;
IO_PORT "led[2]"   IO_TYPE=LVCMOS33 DRIVE=8;
IO_PORT "led[3]"   IO_TYPE=LVCMOS33 DRIVE=8;
IO_PORT "led[4]"   IO_TYPE=LVCMOS33 DRIVE=8;
IO_PORT "led[5]"   IO_TYPE=LVCMOS33 DRIVE=8;

// ── I2S Audio Interface ────────────────────────────────────────────────────
// Using right-side pin header (active-low active, active-low active)
// Pin assignments use the bottom of the right header for easy wiring.
//
// Tang Nano 20K right header (top to bottom):
//   5V, GND, 3.3V, then GPIO pins 73,74,75,76,77,48,49,26,27,28,29,30,31,32,33,34
//
// Wiring plan (right header, bottom pins):
//   Pin 76 = BCK  (shared clock, directly adjacent for short traces)
//   Pin 77 = LRCK (shared word clock)
//   Pin 48 = ADC DOUT (data from PCM1802)
//   Pin 49 = DAC DIN  (data to PCM5102)
//
// tangamp_top.v uses: adc_bck, adc_lrck, dac_bck, dac_lrck (shared from same signal)
// Only need 4 pins: bck_out, lrck_out, adc_dout_in, dac_din_out

// I2S Clocks (shared between ADC and DAC — directly wired in tangamp_top.v)
//   BCK  → wire to both PCM1802.BCK and PCM5102.BCK
//   LRCK → wire to both PCM1802.LRCK and PCM5102.LRCK
IO_LOC  "adc_bck"   76;
IO_PORT "adc_bck"   IO_TYPE=LVCMOS33 DRIVE=8;
IO_LOC  "adc_lrck"  77;
IO_PORT "adc_lrck"  IO_TYPE=LVCMOS33 DRIVE=8;

// I2S ADC data (PCM1802/PCM1808 DOUT → FPGA)
IO_LOC  "adc_dout"  48;
IO_PORT "adc_dout"  IO_TYPE=LVCMOS33 PULL_MODE=DOWN;

// I2S DAC data (FPGA → PCM5102 DIN)
IO_LOC  "dac_din"   49;
IO_PORT "dac_din"   IO_TYPE=LVCMOS33 DRIVE=8;

// I2S MCLK out (FPGA → PCM1808 SCK) — 18 MHz from PLL
IO_LOC  "mclk_out"  75;
IO_PORT "mclk_out"  IO_TYPE=LVCMOS33 DRIVE=8;

// DAC BCK/LRCK share the same physical wires as ADC —
// connect PCM5102.BCK to same wire as pin 76, PCM5102.LRCK to pin 77.
// In tangamp_top.v: dac_bck and dac_lrck are assigned from the same
// internal signals as adc_bck and adc_lrck, so we only need the ADC pins
// as outputs. The DAC reads from the same physical wires.

// ── Onboard MicroSD Card Slot (SPI mode) ──────────────────────────────────
IO_LOC  "sd_clk"    83;
IO_PORT "sd_clk"    IO_TYPE=LVCMOS33 DRIVE=8;
IO_LOC  "sd_cmd"    82;
IO_PORT "sd_cmd"    IO_TYPE=LVCMOS33 DRIVE=8;
IO_LOC  "sd_dat0"   84;
IO_PORT "sd_dat0"   IO_TYPE=LVCMOS33 PULL_MODE=UP;
IO_LOC  "sd_dat1"   85;
IO_PORT "sd_dat1"   IO_TYPE=LVCMOS33 DRIVE=8;
IO_LOC  "sd_dat2"   80;
IO_PORT "sd_dat2"   IO_TYPE=LVCMOS33 DRIVE=8;
IO_LOC  "sd_dat3"   81;
IO_PORT "sd_dat3"   IO_TYPE=LVCMOS33 DRIVE=8;
