FROM ubuntu:24.04

RUN apt-get update && apt-get install -y --no-install-recommends \
    yosys \
    nextpnr-gowin \
    python3 python3-pip python3-numpy \
    iverilog \
    git \
    && rm -rf /var/lib/apt/lists/*

# Apycula for Gowin bitstream packing
RUN pip3 install --break-system-packages apycula

WORKDIR /project
