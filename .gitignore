fpga/impl/gwsynthesis/
fpga/impl/pnr/*.db
fpga/impl/pnr/*.log
fpga/impl/pnr/*.timing_paths
fpga/impl/pnr/*.html

# ── Node modules ─────────────────────────────────────────────────────────
ui/node_modules/

# ── Caches ───────────────────────────────────────────────────────────────
synth_cache/
__pycache__/
*.pyc

# ── Test results ─────────────────────────────────────────────────────────
test_results.json

# ── SPICE intermediates ──────────────────────────────────────────────────
spice_*.cir

# ── NOTE: hex LUT files (data/*.hex) and cabinet IRs ────────────────────
